# ============================================
# ATEPSA — variables de entorno
# Copiar a .env (dev) o /opt/atepsa-reportes/.env (prod) y completar.
# Nunca commitear el .env real.
# ============================================

# --- App Next.js ---
NODE_ENV=production
NEXTAUTH_URL=https://panel.atepsa.org.ar
NEXTAUTH_SECRET=                       # openssl rand -base64 32
INTERNAL_API_SECRET=                   # openssl rand -base64 32 — usado por n8n para llamar a /api/internal/*

# --- Database ---
DATABASE_URL=postgres://app_user:CHANGEME@postgres:5432/atepsa
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=atepsa
POSTGRES_USER=app_user

# --- WhatsApp provider ---
WHATSAPP_PROVIDER=evolution            # evolution | meta

# Evolution API
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=                     # se setea al crear instancia
EVOLUTION_INSTANCE_NAME=atepsa

# Meta Cloud API (futuro)
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- Transcriber ---
TRANSCRIBER_URL=http://transcriber:8000
WHISPER_MODEL=medium                   # tiny | base | small | medium | large
WHISPER_COMPUTE_TYPE=int8

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGEME
N8N_HOST=n8n.atepsa.org.ar
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_ENCRYPTION_KEY=                    # openssl rand -base64 32
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_DATABASE=atepsa
N8N_DB_POSTGRESDB_USER=${POSTGRES_USER}   # mismo usuario que la app, schema separado
N8N_DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
N8N_DB_POSTGRESDB_SCHEMA=n8n

# --- Nginx + SSL ---
# Los certificados SSL se gestionan con certbot en el host, no en Docker.
# Comando inicial (una vez que el DNS apunte al VPS):
#   certbot --nginx -d panel.atepsa.org.ar -d n8n.atepsa.org.ar -d evolution.atepsa.org.ar
CERTBOT_EMAIL=admin@atepsa.org.ar      # email para notificaciones de Let's Encrypt

# --- Operacional ---
TZ=America/Argentina/Buenos_Aires
LOG_LEVEL=info                         # debug | info | warn | error
