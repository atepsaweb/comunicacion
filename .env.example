# ============================================
# ATEPSA — variables de entorno
# Copiar a /opt/atepsa-reportes/repo/infra/.env en prod y completar.
# Nunca commitear el .env real.
# ============================================

# --- App Next.js ---
NODE_ENV=production
NEXTAUTH_URL=https://panel.atepsa.org.ar
NEXTAUTH_SECRET=                       # openssl rand -base64 32
INTERNAL_API_SECRET=                   # openssl rand -base64 32 — usado por n8n para llamar a /api/internal/*

# --- Database ---
DATABASE_URL=postgres://app_user:CHANGEME@postgres:5432/atepsa
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=atepsa
POSTGRES_USER=app_user

# --- WhatsApp provider ---
WHATSAPP_PROVIDER=waha                 # waha | meta

# WAHA (whatsapp-web.js / Chromium) — servicio Docker "wppconnect"
WAHA_URL=http://wppconnect:3000        # URL interna Docker (host: 127.0.0.1:8081)
WPPCONNECT_SECRET_KEY=                 # openssl rand -hex 32 — API key de WAHA
WAHA_SESSION=default                   # nombre de la sesión WAHA (default si no se configura)

# Meta Cloud API (futuro — Fase 10)
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- Transcriber ---
TRANSCRIBER_URL=http://transcriber:8000
WHISPER_MODEL=medium                   # tiny | base | small | medium | large
WHISPER_COMPUTE_TYPE=int8

# --- n8n ---
# El primer acceso a https://n8n.atepsa.org.ar te pide crear la cuenta admin.
N8N_HOST=n8n.atepsa.org.ar
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=                    # openssl rand -base64 32
N8N_EDITOR_BASE_URL=https://n8n.atepsa.org.ar/
WEBHOOK_URL=https://n8n.atepsa.org.ar/
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=atepsa
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
DB_POSTGRESDB_SCHEMA=n8n

# --- Nginx + SSL ---
# Los certificados SSL se gestionan con certbot en el host, no en Docker.
# Comando inicial (una vez que el DNS apunte al VPS):
#   certbot --nginx -d panel.atepsa.org.ar -d n8n.atepsa.org.ar -d evolution.atepsa.org.ar
CERTBOT_EMAIL=admin@atepsa.org.ar      # email para notificaciones de Let's Encrypt

# --- Operacional ---
TZ=America/Argentina/Buenos_Aires
LOG_LEVEL=info                         # debug | info | warn | error
