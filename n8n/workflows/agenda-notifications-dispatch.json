{
  "name": "agenda-notifications-dispatch",
  "active": true,
  "nodes": [
    {
      "id": "node-schedule",
      "name": "Cron cada 5 min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/5 * * * *"
            }
          ]
        }
      }
    },
    {
      "id": "node-manual",
      "name": "Disparo manual",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [240, 460],
      "parameters": {}
    },
    {
      "id": "node-dispatch",
      "name": "Despachar notificaciones",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 380],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.NEXTJS_INTERNAL_URL }}/api/internal/agenda/notifications/dispatch",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-internal-secret",
              "value": "={{ $env.INTERNAL_API_SECRET }}"
            }
          ]
        },
        "options": {
          "timeout": 55000
        }
      }
    },
    {
      "id": "node-log",
      "name": "Log resultado",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [720, 380],
      "parameters": {}
    }
  ],
  "connections": {
    "Cron cada 5 min": {
      "main": [[{ "node": "Despachar notificaciones", "type": "main", "index": 0 }]]
    },
    "Disparo manual": {
      "main": [[{ "node": "Despachar notificaciones", "type": "main", "index": 0 }]]
    },
    "Despachar notificaciones": {
      "main": [[{ "node": "Log resultado", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "timezone": "America/Argentina/Buenos_Aires",
    "saveManualExecutions": true,
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "last"
  }
}
